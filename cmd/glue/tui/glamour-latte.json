{
  "document":      {"block_prefix": "\n", "block_suffix": "\n", "color": "#4c4f69", "margin": 2},
  "block_quote":   {"indent": 1, "indent_token": "│ ", "color": "#6c6f85"},
  "paragraph":     {},
  "list":          {"level_indent": 2},
  "heading":       {"block_suffix": "\n", "color": "#8839ef", "bold": true},
  "h1":            {"prefix": "# ", "color": "#8839ef", "bold": true},
  "h2":            {"prefix": "## ", "color": "#8839ef"},
  "h3":            {"prefix": "### ", "color": "#ea76cb"},
  "h4":            {"prefix": "#### ", "color": "#fe640b"},
  "h5":            {"prefix": "##### ", "color": "#40a02b"},
  "h6":            {"prefix": "###### ", "color": "#209fb5", "bold": false},
  "text":          {},
  "strikethrough": {"crossed_out": true},
  "emph":          {"italic": true, "color": "#4c4f69"},
  "strong":        {"bold": true, "color": "#8839ef"},
  "hr":            {"color": "#bcc0cc", "format": "\n──────────\n"},
  "item":          {"block_prefix": "• ", "color": "#8839ef"},
  "enumeration":   {"block_prefix": ". ", "color": "#8839ef"},
  "task":          {"ticked": "[✓] ", "unticked": "[ ] "},
  "link":          {"color": "#1e66f5", "underline": true},
  "link_text":     {"color": "#209fb5", "bold": true},
  "image":         {"color": "#ea76cb", "underline": true},
  "image_text":    {"color": "#6c6f85", "format": "Image: {{.text}} →"},
  "code":          {"prefix": " ", "suffix": " ", "color": "#fe640b", "background_color": "#ccd0da"},
  "code_block":    {"color": "#4c4f69", "margin": 2, "chroma": {"theme": "catppuccin-latte"}},
  "table":                  {},
  "definition_list":        {},
  "definition_term":        {},
  "definition_description": {"block_prefix": "\n🠶 "},
  "html_block":             {},
  "html_span":              {}
}
